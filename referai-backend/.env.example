# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# --- DeepSeek (required for job parsing, resume extraction, employee discovery) ---
# Sign up at https://platform.deepseek.com — free tier is enough for development
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- GitHub (required for live employee search via GitHub org/user API) ---
# Create a Personal Access Token at https://github.com/settings/tokens
# Scopes needed: read:user, read:org  (no write scopes required)
GITHUB_PAT=your_github_pat_here

# --- Ollama (optional — local LLM for AI career coaching tips) ---
# Install from https://ollama.com, then: ollama pull llama3.2:3b && ollama serve
# The app works without this; AI coaching sections show a static fallback instead.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
