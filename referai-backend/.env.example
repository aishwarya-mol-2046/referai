# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# --- AI resume extraction (set ONE of these) ---
# DeepSeek: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini: https://aistudio.google.com/apikey  (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash   # optional override, default is gemini-2.0-flash

# Priority: DeepSeek is tried first, then Gemini, then keyword fallback.
# Set only the one you have. Both can be set at once.

# --- GitHub (employee profile search via GitHub API) ---
GITHUB_PAT=your_github_pat_here

# --- Web search (employee discovery via LinkedIn snippets) ---
# Brave Search API — 2000 free queries/month, no credit card required
# Sign up: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Google Custom Search — 100 free queries/day (optional, used if Brave not set)
# Create a CSE at: https://programmablesearchengine.google.com/
# Get API key at:  https://console.cloud.google.com/apis/credentials
# GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
# GOOGLE_CSE_ID=your_google_cse_id_here

# --- Ollama (optional — local LLM for career coaching tips) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
